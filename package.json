{
  "name": "zuupee-mcp",
  "private": true,
  "description": "Zuupee MCP monorepo — server, client, and chatbot stack",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:integration": "pnpm -C mcp-client test:integration",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev:chat": "pnpm -C chat-api dev",
    "dev:widget": "pnpm -C chat-widget dev",
    "dev:mcp-client": "pnpm -C mcp-client dev",
    "dev:mock-orders": "pnpm -C mock-api-server dev",
    "dev:orchestrator": "pnpm -C chat-orchestrator dev",
    "docker:chat": "docker compose --env-file .env.local -f docker-compose.chat.yml up --build",
    "load-test:chat": "pnpm -C chat-api load-test"
  },
  "devDependencies": {
    "oxfmt": "0.55.0"
  },
  "engines": {
    "node": ">=22"
  }
}
