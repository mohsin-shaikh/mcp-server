# Server
MCP_SERVER_NAME=mcp-server
MCP_SERVER_VERSION=0.1.0
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3100
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PATH=/mcp
MCP_HTTP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
MCP_CORS_ORIGINS=
MCP_MODULES=meta,http,json,datetime,docs
READ_ONLY=false
LOG_LEVEL=info

# Auth (HTTP transport)
MCP_AUTH_MODE=none
MCP_API_KEY=

# Built-in HTTP tool limits
HTTP_TOOL_ALLOWED_HOSTS=
HTTP_TOOL_MAX_RESPONSE_BYTES=1048576
HTTP_TOOL_TIMEOUT_MS=10000

# Filesystem module (opt-in; add "filesystem" to MCP_MODULES)
FS_ROOT=
FS_MAX_READ_BYTES=1048576

# Plugins (local path; add plugin id to MCP_MODULES)
MCP_PLUGINS_DIR=./plugins

# Orders plugin (add "orders" to MCP_MODULES)
ORDERS_API_BASE_URL=
ORDERS_API_KEY=
ORDERS_API_ALLOWED_HOSTS=
ORDERS_API_TIMEOUT_MS=10000

# OpenTelemetry metrics (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/metrics

# OpenAPI module (opt-in; add "openapi" to MCP_MODULES)
OPENAPI_SPEC_URL=
OPENAPI_CACHE_TTL_MS=300000
