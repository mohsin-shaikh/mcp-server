{
  "name": "@zuupee/mcp-client",
  "version": "0.1.0",
  "description": "MCP client SDK for connecting to one or more MCP servers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx scripts/smoke.ts",
    "build": "tsup",
    "pretest": "pnpm -C ../mcp-server build",
    "test": "vitest run",
    "test:integration": "vitest run tests/*.integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/client": "2.0.0-alpha.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22"
  }
}
