{
  "name": "@zuupee/chat-api",
  "version": "0.1.0",
  "description": "HTTP API for the Zuupee website chatbot",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zuupee/chat-orchestrator": "workspace:*",
    "@zuupee/mcp-client": "workspace:*",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@hono/node-server": "^1.19.9",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22"
  }
}
