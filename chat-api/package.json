{
  "name": "@zuupee/chat-api",
  "version": "0.1.0",
  "description": "HTTP API for the Zuupee website chatbot",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "load-test": "tsx scripts/load-test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@zuupee/chat-orchestrator": "workspace:*",
    "@zuupee/mcp-client": "workspace:*",
    "hono": "^4.12.26",
    "pino": "^9.6.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22"
  }
}
