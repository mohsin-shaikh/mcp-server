# LLM (chat-orchestrator) — copy to .env.local at repo root
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# MCP servers (mcp-client) — path to JSON config or inline via chat-api
MCP_SERVERS_CONFIG=./config/mcp-servers.chat.example.json
MCP_CORE_API_KEY=
MCP_ORDERS_API_KEY=

# Orders plugin (mcp-server) — point at mock-api-server for local dev
ORDERS_API_BASE_URL=http://127.0.0.1:3999
ORDERS_API_KEY=
ORDERS_API_ALLOWED_HOSTS=127.0.0.1,localhost

# Mock API server (mock-api-server)
MOCK_API_HOST=127.0.0.1
MOCK_API_PORT=3999
MOCK_API_DATA_PATH=

# Chat API
CHAT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
CHAT_RATE_LIMIT_RPM=20
CHAT_PORT=3200
CHAT_API_KEY=

# Session store (optional Redis for horizontal scale)
CHAT_REDIS_URL=
CHAT_SESSION_TTL_SECONDS=86400

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Environment-specific MCP config (when MCP_SERVERS_CONFIG is unset)
CHAT_ENV=development

# Orchestrator
CHAT_MAX_TOOL_STEPS=10
CHAT_TOOL_ALLOWLIST=
CHAT_SYSTEM_PROMPT=
CHAT_READ_ONLY=false
