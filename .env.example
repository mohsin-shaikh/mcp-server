# LLM (chat-orchestrator)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# MCP servers (mcp-client) — path to JSON config or inline via chat-api
MCP_SERVERS_CONFIG=./config/mcp-servers.dev.json
MCP_CORE_API_KEY=

# Chat API
CHAT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CHAT_RATE_LIMIT_RPM=20
CHAT_PORT=3200

# Orchestrator
CHAT_MAX_TOOL_STEPS=10
CHAT_TOOL_ALLOWLIST=
CHAT_SYSTEM_PROMPT=
