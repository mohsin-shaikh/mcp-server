# Server
MCP_SERVER_NAME=mcp-server
MCP_SERVER_VERSION=0.1.0
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3100
MCP_MODULES=meta,http,json,datetime
READ_ONLY=false
LOG_LEVEL=info

# Auth (HTTP transport / optional tool gating)
MCP_AUTH_MODE=none
MCP_API_KEY=

# Built-in HTTP tool limits
HTTP_TOOL_ALLOWED_HOSTS=
HTTP_TOOL_MAX_RESPONSE_BYTES=1048576
HTTP_TOOL_TIMEOUT_MS=10000

# Filesystem module (opt-in; add "filesystem" to MCP_MODULES)
FS_ROOT=
FS_MAX_READ_BYTES=1048576
