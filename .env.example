# LLM (chat-orchestrator) — copy to .env.local at repo root
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# MCP servers (mcp-client) — path to JSON config or inline via chat-api
MCP_SERVERS_CONFIG=./config/mcp-servers.chat.example.json
MCP_CORE_API_KEY=
MCP_ORDERS_API_KEY=

# Orders plugin (mcp-server) — point at mock-api-server for local dev
ORDERS_API_BASE_URL=http://127.0.0.1:3999
ORDERS_API_KEY=
ORDERS_API_ALLOWED_HOSTS=127.0.0.1,localhost

# Mock orders API (mock-api-server)
MOCK_API_HOST=127.0.0.1
MOCK_API_PORT=3999
MOCK_API_DATA_PATH=

# Chat API
CHAT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CHAT_RATE_LIMIT_RPM=20
CHAT_PORT=3200
CHAT_API_KEY=

# Orchestrator
CHAT_MAX_TOOL_STEPS=10
CHAT_TOOL_ALLOWLIST=
CHAT_SYSTEM_PROMPT=
CHAT_READ_ONLY=false
