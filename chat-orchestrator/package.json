{
  "name": "@zuupee/chat-orchestrator",
  "version": "0.1.0",
  "description": "Custom ReAct agent loop for the Zuupee website chatbot",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
